# AI Services Shared Defaults
# Copy to /srv/data/ai-services/defaults/shared.env and edit as needed.
# This file contains NON-SECRET defaults only.
#
# Secrets (API keys, tokens) belong in /run/secrets/ai-services-shared-env
# managed by sops-nix.
#
# Environment file precedence (later wins on conflict):
#   1. /srv/data/ai-services/defaults/shared.env (this file)
#   2. /run/secrets/ai-services-shared-env (shared secrets)
#   3. /run/secrets/<service> (service-specific secrets)

# Default model provider (used by services that support it)
# Examples: openrouter, nvidia, ollama, custom
AI_SERVICES_DEFAULT_PROVIDER=custom

# Default model name
# This is the fallback model when no service-specific model is configured
AI_SERVICES_DEFAULT_MODEL=qwen/qwen3-coder-480b-a35b-instruct

# Provider base URLs (non-secret configuration)
# These can be overridden per-service if needed
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Common runtime flags
# NODE_OPTIONS=--max-old-space-size=4096

# Logging level (debug, info, warn, error)
AI_SERVICES_LOG_LEVEL=info
