+func (a *Adapter) runXS(ctx context.Context, args ...string) ([]byte, error) {
+	return a.runCmd(ctx, strings.TrimSpace(a.cfg.Command), args...)
+}
+
+func (a *Adapter) runXSWithInput(ctx context.Context, input []byte, args ...string) ([]byte, error) {
+	cmd := exec.CommandContext(ctx, strings.TrimSpace(a.cfg.Command), args...)
+	if len(input) > 0 {
+		cmd.Stdin = bytes.NewReader(input)
+	}
+	out, err := cmd.CombinedOutput()
+	if err != nil {
+		return out, errors.New(strings.TrimSpace(err.Error()))
+	}
+	return out, nil
+}
+
+func (a *Adapter) decodeEvents(ctx context.Context, raw []byte, sessionID string) ([]eventlog.Event, error) {
+	out := make([]eventlog.Event, 0, 64)
+	s := bufio.NewScanner(bytes.NewReader(raw))
+	s.Buffer(make([]byte, 0, 64*1024), 8*1024*1024)
+	for s.Scan() {
+		line := strings.TrimSpace(s.Text())
+		if line == "" {
+			continue
+		}
+		var frame map[string]any
+		if err := json.Unmarshal([]byte(line), &frame); err != nil {
+			continue
+		}
+		payload := a.extractPayload(ctx, frame)
+		if payload == nil {
+			continue
+		}
+		e, ok := payloadToEvent(payload)
+		if !ok {
+			continue
+		}
+		if e.SessionID != sessionID {
+			continue
+		}
+		out = append(out, e)
+	}
+	if err := s.Err(); err != nil {
+		return nil, err
+	}
+	return out, nil
+}
+
+func (a *Adapter) extractPayload(ctx context.Context, raw any) map[string]any {
+	switch v := raw.(type) {
+	case map[string]any:
+		if _, ok := v["kind"]; ok {
+			return v
+		}
+		if hash := asString(v["hash"]); hash != "" {
+			if payload := a.fetchCASPayload(ctx, hash); payload != nil {
+				return a.extractPayload(ctx, payload)
+			}
+		}
+		for _, key := range []string{"content", "payload", "body", "data"} {
+			if nested, ok := v[key]; ok {
+				if payload := a.extractPayload(ctx, nested); payload != nil {
+					return payload
+				}
+			}
+		}
+		return v
+	case string:
+		trimmed := strings.TrimSpace(v)
+		if trimmed == "" {
+			return nil
+		}
+		var out any
+		if err := json.Unmarshal([]byte(trimmed), &out); err != nil {
+			return map[string]any{"value": trimmed}
+		}
+		return a.extractPayload(ctx, out)
+	default:
+		return nil
+	}
+}
+
+func (a *Adapter) fetchCASPayload(ctx context.Context, hash string) map[string]any {
+	out, err := a.runXS(ctx, "cas", a.addr(), hash)
+	if err != nil {
+		return nil
+	}
+	text := strings.TrimSpace(string(out))
+	if text == "" {
+		return nil
+	}
+	var payload map[string]any
+	if err := json.Unmarshal([]byte(text), &payload); err == nil {
+		return payload
+	}
+	return map[string]any{"value": text}
+}
+
+func payloadToEvent(payload map[string]any) (eventlog.Event, bool) {
+	id := firstString(payload, "event_id", "id")
+	sessionID := firstString(payload, "session_id")
+	branchID := firstString(payload, "branch_id")
+	kind := firstString(payload, "kind")
+	timestamp := firstString(payload, "timestamp", "ts")
+	if id == "" || sessionID == "" || branchID == "" || kind == "" {
+		return eventlog.Event{}, false
+	}
+	ts, err := time.Parse(time.RFC3339Nano, timestamp)
+	if err != nil {
+		ts, err = time.Parse(time.RFC3339, timestamp)
+		if err != nil {
+			ts = time.Now().UTC()
+		}
+	}
+
+	meta := map[string]any{}
+	if m, ok := payload["meta"].(map[string]any); ok {
+		meta = m
+	}
+	refs := toStringSlice(payload["refs"])
+
+	return eventlog.Event{
+		ID:            id,
+		SessionID:     sessionID,
+		TS:            ts,
+		Kind:          kind,
+		BranchID:      branchID,
+		ParentEventID: firstString(payload, "parent_event_id"),
+		Refs:          refs,
+		Meta:          meta,
+		BlobRef:       firstString(payload, "blob_ref"),
+	}, true
+}
